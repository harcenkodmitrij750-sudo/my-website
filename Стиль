body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #f0f4f8;
}

header {
    background-color: #2c3e50;
    padding: 15px;
}

nav a {
    color: white;
    margin-right: 20px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    text-decoration: underline;
}

.container {
    padding: 20px;
}

h1 {
    color: #2c3e50;
}

img {
    max-width: 400px;
    display: block;
    margin-top: 10px;
}
